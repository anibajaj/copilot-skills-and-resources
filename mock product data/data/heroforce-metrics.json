  "dailyActivationFunnel": {
    "title": "Daily activation funnel (drop-off by step)",
    "basis": "Daily active users, June 2026",
    "note2": "View vs. do. Step 2 = the rep saw their deals (an impression). Step 3 = the rep actually updated something (logged activity, advanced a stage, updated an account). Reps reach and view their work fine; the fall is that they look but don't log.",
    "stages": [
      {
        "stage": 1,
        "name": "Login",
        "users": 80510,
        "pctOfTop": 100,
        "dropFromPrev": 0
      },
      {
        "stage": 2,
        "name": "Viewed their deals",
        "users": 74100,
        "pctOfTop": 92,
        "dropFromPrev": 8
      },
      {
        "stage": 3,
        "name": "Took a meaningful action",
        "users": 47300,
        "pctOfTop": 59,
        "dropFromPrev": 36
      },
      {
        "stage": 4,
        "name": "Returned the next day",
        "users": 41900,
        "pctOfTop": 52,
        "dropFromPrev": 11
      }
    ],
    "biggestDropStage": 3,
    "note": "Largest single-step fall is Step 2 -> Step 3 — 74.1k viewed their deals but only 47.3k updated anything (a 36% drop). Reps see their work fine; they just don't log it. Evidence (feedback + personas) points to field/phone reps who are on calls all day and find updating the CRM too cumbersome to do mid-call, so the write slips to 'later' and often never happens."
  },
